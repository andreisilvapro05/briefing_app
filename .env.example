# ============================================================
# FYSI BRIEFING — variáveis de ambiente
# Copie este arquivo para .env.local e preencha cada chave.
# ============================================================

# ----- Supabase -----
# Crie um projeto em https://supabase.com e copie URL + anon + service_role
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Bucket de Storage usado pelos uploads do briefing.
# Crie no painel Supabase com acesso público de leitura.
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=briefing-uploads

# ----- OpenAI (transcrição de áudio via Whisper) -----
OPENAI_API_KEY=sk-...
# Modelo padrão Whisper (pode ser whisper-1 ou gpt-4o-transcribe se disponível)
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ----- Resend (e-mail transacional) -----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Fysi Lab <onboarding@fysilab.com>

# E-mail da equipe que recebe o briefing inteiro a cada envio.
TEAM_EMAIL=fysilabdigital@gmail.com

# ----- ClickUp (criação de tarefa ao concluir briefing) -----
CLICKUP_API_TOKEN=pk_...
# ID da lista onde a tarefa será criada (Workspace > Space > Folder > List)
CLICKUP_LIST_ID=

# ----- Cloudflare Turnstile (anti-spam invisível) -----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----- Admin -----
# E-mails (separados por vírgula) — método legado de entrar via magic-link.
ADMIN_EMAILS=karine@fysilab.com,andrei@fysilab.com
# Senha compartilhada do painel (preferido). Use senha forte em produção.
ADMIN_PASSWORD=troque-esta-senha

# ----- Acesso do cliente -----
# Código de acesso global do briefing. O cliente reentra de qualquer aparelho
# em /entrar com o WhatsApp + este código (o WhatsApp identifica o briefing).
# É um código único pra todos os clientes — comunique-o no onboarding.
# SEMPRE defina em produção (o default "fysi" é só pra desenvolvimento).
CLIENT_ACCESS_CODE=troque-este-codigo

# ----- App -----
# Base pública usada nos links de magic-link (defina o domínio em produção).
NEXT_PUBLIC_APP_URL=http://localhost:3000
